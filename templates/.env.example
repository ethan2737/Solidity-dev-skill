# 复制此文件为 .env 并填入你的真实值
# 注意：.env 文件不应提交到 git，已添加到 .gitignore

# ===== 本地开发 =====
# 本地 Hardhat 节点不需要配置，默认使用预配置账户

# ===== Sepolia 测试网 =====
# 获取测试币：https://sepoliafaucet.com/
PRIVATE_KEY=你的以太坊私钥（不要泄露）
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/你的 INFURA_API_KEY
INFURA_API_KEY=你的 Infura API 密钥

# ===== 以太坊主网 =====
# 警告：主网交易需要真实 ETH，请谨慎操作
MAINNET_RPC_URL=https://mainnet.infura.io/v3/你的 INFURA_API_KEY
ETHERSCAN_API_KEY=你的 Etherscan API 密钥（用于合约验证）

# ===== RPC URL 替代方案 =====
# Alchemy: https://www.alchemy.com/
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/你的 ALCHEMY_API_KEY
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/你的 ALCHEMY_API_KEY
